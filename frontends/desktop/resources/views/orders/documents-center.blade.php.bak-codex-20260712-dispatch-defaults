@push('scripts')
    <script>
        (() => {
            const root = document.querySelector('[data-doc-center-root]');
            if (!root) {
                return;
            }

            const bulkDispatchForm = document.getElementById('orderDocumentsDispatchForm');
            const rowCheckboxes = Array.from(root.querySelectorAll('[data-document-row-checkbox]'));
            const forms = Array.from(root.querySelectorAll('[data-selected-documents-target]'));
            const selectAllButton = root.querySelector('[data-doc-select-all]');
            const clearAllButton = root.querySelector('[data-doc-clear-all]');
            const selectionCount = root.querySelector('[data-doc-selection-count]');
            const selectionAlert = root.querySelector('[data-doc-selection-alert]');
            const submitButtons = Array.from(root.querySelectorAll('[data-doc-submit-button]'));

            const hideSelectionAlert = () => {
                if (!selectionAlert) {
                    return;
                }

                selectionAlert.textContent = '';
                selectionAlert.classList.add('d-none');
            };

            const showSelectionAlert = (message) => {
                if (!selectionAlert) {
                    window.alert(message);
                    return;
                }

                selectionAlert.textContent = message;
                selectionAlert.classList.remove('d-none');
                selectionAlert.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            };

            const syncSelectedDocuments = () => {
                const selected = rowCheckboxes
                    .filter((checkbox) => checkbox.checked)
                    .map((checkbox) => checkbox.value);

                forms.forEach((form) => {
                    form.querySelectorAll('input[data-generated-document-id]').forEach((input) => input.remove());

                    selected.forEach((value) => {
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'document_ids[]';
                        input.value = value;
                        input.setAttribute('data-generated-document-id', '1');
                        form.appendChild(input);
                    });
                });

                if (selectionCount) {
                    selectionCount.textContent = selected.length === 0
                        ? 'Nenhum documento selecionado.'
                        : selected.length === 1
                            ? '1 documento selecionado.'
                            : `${selected.length} documentos selecionados.`;
                }

                submitButtons.forEach((button) => {
                    button.disabled = selected.length === 0;
                });

                if (selected.length > 0) {
                    hideSelectionAlert();
                }
            };

            rowCheckboxes.forEach((checkbox) => {
                checkbox.addEventListener('change', syncSelectedDocuments);
            });

            if (selectAllButton) {
                selectAllButton.addEventListener('click', () => {
                    rowCheckboxes.forEach((checkbox) => {
                        checkbox.checked = true;
                    });
                    syncSelectedDocuments();
                });
            }

            if (clearAllButton) {
                clearAllButton.addEventListener('click', () => {
                    rowCheckboxes.forEach((checkbox) => {
                        checkbox.checked = false;
                    });
                    syncSelectedDocuments();
                });
            }

            if (bulkDispatchForm) {
                bulkDispatchForm.addEventListener('submit', (event) => {
                    const selectedCount = rowCheckboxes.filter((checkbox) => checkbox.checked).length;
                    if (selectedCount > 0) {
                        hideSelectionAlert();
                        return;
                    }

                    event.preventDefault();
                    showSelectionAlert(
                        event.submitter?.getAttribute('data-selection-required-message')
                        || 'Selecione ao menos um documento do acervo antes de continuar.'
                    );
                });
            }

            forms.forEach((form) => {
                form.addEventListener('submit', (event) => {
                    const selectedCount = rowCheckboxes.filter((checkbox) => checkbox.checked).length;
                    if (selectedCount > 0) {
                        hideSelectionAlert();
                        return;
                    }

                    event.preventDefault();
                    showSelectionAlert(
                        form.getAttribute('data-selection-required-message')
                        || 'Selecione ao menos um documento do acervo antes de continuar.'
                    );
                });
            });

            syncSelectedDocuments();
        })();
    </script>
