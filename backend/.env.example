APP_NAME="Sistema ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
# Endereço público do backend usado nos links enviados a clientes (aprovação de orçamento etc.).
# Ex.: https://erp.suaempresa.com.br — vazio usa APP_URL.
APP_PUBLIC_URL=
APP_TIMEZONE=America/Sao_Paulo
FRONTEND_DESKTOP_URL=http://127.0.0.1:8080
COLLECTOR_API_TOKEN=
COLLECTOR_PAIRING_TTL_MINUTES=30
COLLECTOR_LOCAL_ROOT=C:\\JovemTechBenchCollector
COLLECTOR_PUBLISHED_ROOT=
EQUIPMENT_MODEL_SUGGESTIONS_TIMEOUT=5

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sistema_erp
DB_USERNAME=root
DB_PASSWORD=

# Fonte oficial de clientes para a Central de Atendimento nesta fase.
# Se omitido, reutiliza host/porta/credenciais do DB principal.
SISTEMA_HML_DB_DATABASE=sistema_hml
# SISTEMA_HML_DB_HOST=
# SISTEMA_HML_DB_PORT=
# SISTEMA_HML_DB_USERNAME=
# SISTEMA_HML_DB_PASSWORD=

# Banco separado da Central de Atendimento (mesma instancia MySQL, banco logico proprio)
CHAT_DB_DATABASE=sistema_erp_chat
# CHAT_DB_HOST=
# CHAT_DB_PORT=
# CHAT_DB_USERNAME=
# CHAT_DB_PASSWORD=

WHATSAPP_API_PATH="C:\\xampp\\htdocs\\sistema-hml\\whatsapp-api"
LEGACY_PUBLIC_PATH=
SANCTUM_EXPIRATION=10080

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Gerenciador Central de Arquivos (fail-safe: mantenha off até rollout aprovado)
FILE_MANAGER_MODE=off
FILE_MANAGER_ENABLED_CATEGORIES=
# Allowlist adicional: apenas categorias cujo gate híbrido já foi concluído.
FILE_MANAGER_HYBRID_WRITE_CATEGORIES=company_login_background,company_logo
FILE_MANAGER_ALLOW_WRITES=false
FILE_MANAGER_ALLOW_SCANNER=false
FILE_MANAGER_ALLOW_MUTATING_RECONCILE=false
FILE_MANAGER_ALLOW_ADMIN_STATE_MUTATIONS=false
FILE_MANAGER_ALLOW_PERMANENT_DELETION=false
FILE_MANAGER_BATCH_DOWNLOAD_MAX_FILES=50
FILE_MANAGER_BATCH_DOWNLOAD_MAX_BYTES=104857600
FILE_MANAGER_DISK=local
FILE_MANAGER_LOCK_SECONDS=30
FILE_MANAGER_LOCK_WAIT_SECONDS=5
FILE_MANAGER_PREVIOUS_VERSION_DAYS=7
FILE_MANAGER_TRASH_RETENTION_DAYS=30
FILE_MANAGER_TRASH_PURGE_BATCH_SIZE=250
FILE_MANAGER_SCAN_LIMIT=1000
FILE_MANAGER_SCAN_MAX_DEPTH=12
FILE_MANAGER_SCAN_TIMEOUT_SECONDS=60
FILE_MANAGER_SCAN_PAUSE_MS=0
FILE_MANAGER_AUTOMATIC_SYNC_ENABLED=false
FILE_MANAGER_AUTOMATIC_SYNC_INTERVAL_MINUTES=5
FILE_MANAGER_AUTOMATIC_SYNC_ROOTS=branding,equipment_photos,order_photos,order_files,budget_documents,signatures,chat,legacy_equipment_profiles,legacy_equipment_files,legacy_order_anomalies,legacy_order_state,legacy_order_accessories,legacy_order_checklists,legacy_order_documents,legacy_budgets,legacy_chat,legacy_whatsapp,legacy_users,legacy_system
FILE_MANAGER_AUTOMATIC_SYNC_SCAN_LIMIT=10000
FILE_MANAGER_AUTOMATIC_SYNC_CATALOG_LIMIT=10000
FILE_MANAGER_AUTOMATIC_SYNC_DOMAIN_LINK_LIMIT=10000
FILE_MANAGER_AUTOMATIC_SYNC_MAX_DEPTH=12
FILE_MANAGER_AUTOMATIC_SYNC_LOCK_SECONDS=3600
FILE_MANAGER_PDF_THUMBNAILS_ENABLED=false
FILE_MANAGER_PDF_THUMBNAIL_RENDERER=/usr/bin/pdftocairo
FILE_MANAGER_PDF_THUMBNAIL_DISK=local
FILE_MANAGER_PDF_THUMBNAIL_MAX_DIMENSION=480
FILE_MANAGER_PDF_THUMBNAIL_MAX_BYTES=2097152
FILE_MANAGER_PDF_THUMBNAIL_TIMEOUT_SECONDS=10
FILE_MANAGER_PDF_THUMBNAIL_LOCK_SECONDS=20
FILE_MANAGER_PDF_THUMBNAIL_LOCK_WAIT_SECONDS=5
FILE_MANAGER_PDF_THUMBNAIL_CACHE_SECONDS=86400

# Origens privadas de mídia inbound exigem opt-in exato (separadas por vírgula).
CHAT_TRUSTED_PRIVATE_MEDIA_ORIGINS=

# Tempo real da Central de Atendimento (specs/010-inbox-whatsapp-tempo-real)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="127.0.0.1"
REVERB_PORT=8090
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8090

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Em desenvolvimento local, "log" nao envia e-mail externo.
# A recuperacao de senha exige um canal real de SMTP configurado no backend
# (Configuracoes > Integracoes > E-mail) ou MAIL_MAILER=smtp no proprio ambiente.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
