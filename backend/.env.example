APP_NAME="Sistema ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=America/Sao_Paulo
FRONTEND_DESKTOP_URL=http://127.0.0.1:8080
COLLECTOR_API_TOKEN=
COLLECTOR_PAIRING_TTL_MINUTES=30
COLLECTOR_LOCAL_ROOT=C:\\JovemTechBenchCollector
COLLECTOR_PUBLISHED_ROOT=
EQUIPMENT_MODEL_SUGGESTIONS_TIMEOUT=5

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sistema_erp
DB_USERNAME=root
DB_PASSWORD=

# Fonte oficial de clientes para a Central de Atendimento nesta fase.
# Se omitido, reutiliza host/porta/credenciais do DB principal.
SISTEMA_HML_DB_DATABASE=sistema_hml
# SISTEMA_HML_DB_HOST=
# SISTEMA_HML_DB_PORT=
# SISTEMA_HML_DB_USERNAME=
# SISTEMA_HML_DB_PASSWORD=

# Banco separado da Central de Atendimento (mesma instancia MySQL, banco logico proprio)
CHAT_DB_DATABASE=sistema_erp_chat
# CHAT_DB_HOST=
# CHAT_DB_PORT=
# CHAT_DB_USERNAME=
# CHAT_DB_PASSWORD=

WHATSAPP_API_PATH="C:\\xampp\\htdocs\\sistema-hml\\whatsapp-api"
LEGACY_PUBLIC_PATH=
SANCTUM_EXPIRATION=10080

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# Tempo real da Central de Atendimento (specs/010-inbox-whatsapp-tempo-real)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="127.0.0.1"
REVERB_PORT=8090
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8090

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
