# ============================================================================
# CONFIGURAÇÃO DO AMBIENTE DE PRODUÇÃO
# ============================================================================
# Este arquivo define as variáveis para produção
# Copie para .env.production e ajuste os valores conforme necessário

# Aplicação
APP_NAME="Sistema ERP"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.example.com
FRONTEND_DESKTOP_URL=https://desktop.example.com

# Chave da Aplicação (GERAR COM: php artisan key:generate)
APP_KEY=base64:GERAR_UMA_NOVA_CHAVE_COM_php_artisan_key_generate

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=warning

# Banco de Dados
DB_CONNECTION=mysql
DB_HOST=db.internal
DB_PORT=3306
DB_DATABASE=sistema_hml
DB_USERNAME=erp_app
DB_PASSWORD=GERAR_SENHA_FORTE_AQUI

# Cache
CACHE_DRIVER=redis
REDIS_HOST=redis.internal
REDIS_PASSWORD=GERAR_SENHA_REDIS_AQUI
REDIS_PORT=6379

# Session
SESSION_DRIVER=redis
SESSION_SECURE_COOKIES=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=.example.com

# Sanctum (API Authentication)
SANCTUM_STATEFUL_DOMAINS=app.example.com,web.example.com
SANCTUM_TOKEN_PREFIX=erp
SANCTUM_COOKIE_NAME=erp_token
SANCTUM_COOKIE_LIFETIME=1440
SANCTUM_COOKIE_PATH=/
SANCTUM_COOKIE_DOMAIN=example.com
SANCTUM_SECURE_COOKIES=true
SANCTUM_HTTP_ONLY_COOKIES=true
SANCTUM_SAME_SITE_COOKIES=lax

# CORS - Permitir apenas dominios autorizados
CORS_ALLOWED_ORIGINS="https://app.example.com,https://web.example.com,https://admin.example.com"

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=GERAR_SENHA_AQUI
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 (para armazenamento de arquivos)
AWS_ACCESS_KEY_ID=GERAR_CHAVE_AQUI
AWS_SECRET_ACCESS_KEY=GERAR_CHAVE_SECRETA_AQUI
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=sistema-erp-prod
AWS_URL=https://s3.example.com/sistema-erp-prod

# Queue
QUEUE_CONNECTION=redis

# Sentry (Error Tracking)
SENTRY_LARAVEL_DSN=https://GERAR_DSN_SENTRY@sentry.io/PROJECT_ID

# Rate Limiting
RATE_LIMIT=60

# Timezone
APP_TIMEZONE=America/Sao_Paulo
